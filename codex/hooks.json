{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.codex/hooks/guard-destructive-git.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/.codex/hooks/enforce-git-claw.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
